# ==== Pancake credentials (ชุดเดียวกับที่ใช้ในเวอร์ชัน GAS) ====
# POS API Key: Pancake POS → ตั้งค่า → ขั้นสูง → เชื่อมต่อภายนอก → API Key
POS_API_KEY=
# POS Shop ID: ตัวเลขร้านใน URL ของ POS
POS_SHOP_ID=
# Access Token: pages.fm → บัญชี → ตั้งค่าส่วนตัว → API Access Token
PANCAKE_ACCESS_TOKEN=

# ==== Supabase (Project Settings → API) ====
# URL ของโปรเจกต์ เช่น https://xxxx.supabase.co
SUPABASE_URL=
# service_role key (ความลับ! ใช้เฉพาะ worker — ห้ามใส่ฝั่ง frontend)
SUPABASE_SERVICE_ROLE_KEY=

# ==== รหัสผ่านรวมทีมสำหรับเข้า dashboard (middleware auth — กัน PII/ยอดขายหลุด) ====
# ตั้งเป็นรหัสอะไรก็ได้ที่ทีมใช้ร่วมกัน • ต้องตั้งบน Vercel ด้วย (Production + Preview)
# ถ้าไม่ตั้ง เว็บจะ fail-closed (เข้าไม่ได้) เพื่อความปลอดภัย
DASHBOARD_PASSWORD=
